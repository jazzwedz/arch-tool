# ============================================================
# Team Repository — environment variables
# Copy this file to .env.local and fill in the values.
# .env*.local is gitignored — never commit real secrets.
# ============================================================

# --- Required: Git storage backend ---
# Pick ONE of the two providers below by setting GIT_PROVIDER.
# Defaults to "github" when unset.
#
#   GIT_PROVIDER=github   → store catalog in a GitHub repo
#   GIT_PROVIDER=ado      → store catalog in Azure DevOps Git
#                           (also accepts: "azure-devops")
GIT_PROVIDER=github

# --- Provider: GitHub ---
# Fine-grained PAT with "Contents: Read and write" on the data repo.
# Create at: https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=
# GitHub user or org that owns the data repo.
GITHUB_OWNER=
# Repo name (any empty repo you own; defaults to "arch-data").
GITHUB_REPO=arch-data
# Branch to commit into.
GITHUB_BRANCH=main

# --- Provider: Azure DevOps ---
# Base URL of the organisation (Service) or collection (on-prem Server/TFS):
#   ADO Service:  https://dev.azure.com/{your-org}
#   ADO Server:   https://your-tfs.example.com/DefaultCollection
# No trailing slash.
# ADO_BASE_URL=
# Project name inside the organisation / collection.
# ADO_PROJECT=
# Git repository name (any empty repo).
# ADO_REPO=arch-data
# Branch to commit into.
# ADO_BRANCH=main
# Personal Access Token with at least "Code (Read & Write)" on the repo.
# Create at: https://dev.azure.com/{your-org}/_usersSettings/tokens
# ADO_PAT=

# --- Required: LLM provider ---
# Powers Generate, Blast Radius AI Memo, and Pull-smart.
#
# Pick ONE of the two providers below by setting LLM_PROVIDER.
# Defaults to "anthropic" when unset.
#
#   LLM_PROVIDER=anthropic           → use Anthropic Claude directly
#   LLM_PROVIDER=openai-compatible   → use any OpenAI Chat Completions
#                                      gateway: OpenAI, Azure OpenAI,
#                                      OpenRouter, Together, Groq,
#                                      LiteLLM, Portkey, Cloudflare
#                                      AI Gateway, Ollama, LM Studio, vllm
LLM_PROVIDER=anthropic

# --- Provider: Anthropic ---
# API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Optional model override. Falls back to config.yaml (llm.model)
# then to a built-in default. Example: claude-sonnet-4-20250514.
# ANTHROPIC_MODEL=

# --- Provider: openai-compatible ---
# Base URL of the gateway, no trailing slash. The adapter calls
# {LLM_BASE_URL}/chat/completions. Examples:
#   https://api.openai.com/v1
#   https://your-resource.openai.azure.com/openai/deployments/your-deployment
#   https://openrouter.ai/api/v1
#   https://your-gateway.example.com/v1
# LLM_BASE_URL=
# Bearer token for the gateway.
# LLM_API_KEY=
# Optional model override. Falls back to config.yaml (llm.model)
# then to a built-in default. Example: gpt-4o, claude-3-5-sonnet, etc.
# LLM_MODEL=

# --- Required: single-user password gate ---
# Shared password for the password gate (middleware.ts).
# Set a strong value; users sign in with this on /login.
SITE_PASSWORD=

# --- Optional: Confluence integration ---
# Enables Publish, Open in Confluence, and Pull from Confluence.
# Leave the required block for your edition empty to hide those buttons.
#
# Pick ONE edition by setting CONFLUENCE_EDITION (defaults to "cloud"):
#
#   CONFLUENCE_EDITION=cloud        → Atlassian Cloud, v2 API, Basic auth
#   CONFLUENCE_EDITION=datacenter   → Data Center / Server, v1 API, PAT
CONFLUENCE_EDITION=cloud

# Site root, no trailing slash. Works for both editions:
#   Cloud:      https://your-org.atlassian.net
#   DC/Server:  https://confluence.your-company.com
CONFLUENCE_BASE_URL=

# --- Edition: Cloud ---
# Atlassian account email used with the token below.
CONFLUENCE_EMAIL=
# API token from: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=
# Numeric space ID. Discover via:
#   curl -u "$EMAIL:$TOKEN" "$BASE/wiki/api/v2/spaces?keys=YOURKEY"
CONFLUENCE_SPACE_ID=
# Space key (e.g. TR). Used for nicer URL paths on Cloud, primary
# identifier on Data Center.
CONFLUENCE_SPACE_KEY=

# --- Edition: Data Center / Server ---
# Personal Access Token with read+write on the target space.
# Create at: <BASE>/plugins/personalaccesstokens/usertokens.action
# CONFLUENCE_PAT=
# (CONFLUENCE_SPACE_KEY above is also required on Data Center)

# --- Optional: app self-reference ---
# Public URL of this deployment. Embedded as the "source" link
# on every Confluence page published from this instance.
ARCH_TOOL_PUBLIC_URL=
