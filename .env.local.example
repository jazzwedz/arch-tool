GITHUB_TOKEN=           # PAT so scope: repo (prístup na arch-data)
GITHUB_OWNER=           # owner arch-data repo
GITHUB_REPO=arch-data
GITHUB_BRANCH=main
N8N_ARCH_WEBHOOK_URL=   # URL n8n webhooku v tomto Railway projekte

# Confluence (optional — needed for "Publish/Pull from Confluence" features)
CONFLUENCE_BASE_URL=    # e.g. https://yoursite.atlassian.net
CONFLUENCE_EMAIL=       # Atlassian account email
CONFLUENCE_API_TOKEN=   # API token from id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_SPACE_ID=    # numeric space ID (use REST: GET /wiki/api/v2/spaces?keys=YOURKEY)
CONFLUENCE_SPACE_KEY=   # space key (e.g. TR), used only for nicer URL paths
ARCH_TOOL_PUBLIC_URL=   # public URL of arch-tool, embedded as "source link" in Confluence pages
